# Copy to .env for local emulator, or set as Firebase secret:
#   firebase functions:secrets:set GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here

# Phase 2 RAG setup:
# 1) python scripts/export_rag_models.py --out models_export
# 2) Upload minilm_embed_int8.onnx, minilm_rerank_int8.onnx, vocab.txt
# 3) Set URLs in app/src/main/assets/rag_model_urls.json
# 4) firebase deploy --only firestore:indexes,functions
# 5) Create/confirm VECTOR index on users/{uid}/noteChunks.embedding (384-d, cosine) if console requires it
