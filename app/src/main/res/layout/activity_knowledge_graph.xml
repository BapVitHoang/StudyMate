<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/studymate_background"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/knowledge_graph_title"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textColor="@color/studymate_text_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/studyNextText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:background="@drawable/bg_auth_panel"
        android:padding="@dimen/space_md"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="@color/studymate_text_primary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/rebuildGapsButton"
        style="@style/StudyMateButtonText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rebuild_gaps" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/conceptsRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_md"
        android:layout_weight="1" />
</LinearLayout>
