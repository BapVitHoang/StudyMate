<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/studymate_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/exam_prep_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/studymate_text_primary"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/examTopicInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:hint="@string/exam_prep_topic_hint" />

        <RadioGroup
            android:id="@+id/examModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm">

            <RadioButton
                android:id="@+id/modeOutline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/exam_mode_outline" />

            <RadioButton
                android:id="@+id/modeCheatsheet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/exam_mode_cheatsheet" />

            <RadioButton
                android:id="@+id/modePractice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/exam_mode_practice" />
        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/generateExamButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:text="@string/exam_prep_generate" />

        <ProgressBar
            android:id="@+id/examProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_md"
            android:visibility="gone" />

        <TextView
            android:id="@+id/examResultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/studymate_text_primary" />

        <LinearLayout
            android:id="@+id/examCitationsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/space_md" />
    </LinearLayout>
</ScrollView>
