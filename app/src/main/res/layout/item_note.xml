<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/StudyMateCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_md">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <TextView
            android:id="@+id/itemNoteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/studymate_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/itemNotePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"
            android:maxLines="3"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/studymate_text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/itemNoteCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_primary"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_xs"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_xs"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@color/studymate_chip_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/itemNoteUpdatedAt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:layout_weight="1"
                android:gravity="end"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/studymate_text_secondary" />

        </LinearLayout>

        <TextView
            android:id="@+id/itemNoteTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="@color/studymate_secondary" />

        <TextView
            android:id="@+id/itemNoteReminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:drawablePadding="@dimen/space_xs"
            android:drawableStart="@drawable/ic_reminder_24"
            android:drawableTint="@color/studymate_accent"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/studymate_text_secondary" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
