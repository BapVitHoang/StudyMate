<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/space_lg">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create note"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="@color/studymate_text_primary"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:text="Start blank or choose a study template."
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="@color/studymate_text_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/blankNoteCard"
            style="@style/StudyMateCard"
            android:layout_width="0dp"
            android:layout_height="156dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:strokeColor="@color/studymate_outline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/space_md">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_chip_primary"
                    android:drawableStart="@drawable/ic_note_24"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:gravity="center"
                    android:text="Blank note"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:textColor="@color/studymate_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Write from scratch"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/studymate_text_secondary" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/templateNoteCard"
            style="@style/StudyMateCard"
            android:layout_width="0dp"
            android:layout_height="156dp"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:strokeColor="@color/studymate_outline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/space_md">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_summary_card"
                    android:drawableStart="@drawable/ic_template_24"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:gravity="center"
                    android:text="Template"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:textColor="@color/studymate_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Use a study format"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/studymate_text_secondary" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>
