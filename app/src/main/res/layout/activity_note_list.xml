<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/studymate_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/space_2xl"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/space_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/listTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/my_study_notes"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:textColor="@color/studymate_text_primary"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/statsButton"
                style="@style/StudyMateButtonText"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/study_stats"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="48dp"
                android:text=""
                app:icon="@drawable/ic_stats_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/studymate_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/logoutButton"
                style="@style/StudyMateButtonText"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/logout"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="48dp"
                android:text=""
                app:icon="@drawable/ic_logout_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/studymate_primary" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/study_notes_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/studymate_text_secondary" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:hint="@string/search_notes"
            app:boxBackgroundColor="@color/studymate_surface"
            app:boxBackgroundMode="filled"
            app:boxCornerRadiusBottomEnd="@dimen/field_radius"
            app:boxCornerRadiusBottomStart="@dimen/field_radius"
            app:boxCornerRadiusTopEnd="@dimen/field_radius"
            app:boxCornerRadiusTopStart="@dimen/field_radius"
            app:boxStrokeColor="@color/studymate_outline"
            app:startIconDrawable="@drawable/ic_search_24"
            app:startIconTint="@color/studymate_text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/searchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionSearch"
                android:inputType="text" />

        </com.google.android.material.textfield.TextInputLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/categoryChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="@dimen/space_sm"
                app:singleLine="true"
                app:singleSelection="true" />

        </HorizontalScrollView>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/space_md"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/notesRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="104dp" />

            <TextView
                android:id="@+id/emptyStateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="@dimen/space_lg"
                android:background="@drawable/bg_auth_panel"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:padding="@dimen/space_xl"
                android:text="No notes found"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/studymate_text_secondary"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/notesLoadingProgress"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addNoteFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/space_2xl"
        android:contentDescription="Add note"
        app:backgroundTint="@color/studymate_primary"
        app:srcCompat="@drawable/ic_add_24"
        app:tint="@color/white" />

</FrameLayout>
