<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="StudyMateCard">
        <item name="cardBackgroundColor">@color/studymate_surface</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeColor">@color/studymate_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="StudyMateButtonPrimary" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/field_radius</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="StudyMateButtonOutlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/field_radius</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="strokeColor">@color/studymate_outline</item>
    </style>

    <style name="StudyMateButtonText" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">@dimen/field_radius</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="StudyMateButtonDanger" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">@dimen/field_radius</item>
        <item name="android:textColor">@color/studymate_danger</item>
        <item name="iconTint">@color/studymate_danger</item>
    </style>
</resources>
